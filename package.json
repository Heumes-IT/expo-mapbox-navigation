{
  "name": "@heumes-it/expo-mapbox-navigation",
  "version": "0.1.0-beta.3",
  "description": "Turn-by-turn navigation for React Native / Expo powered by Mapbox Navigation SDK v3. Full-featured: routing, active guidance, voice instructions, map view with route line + puck, lane guidance, speed limits, and more.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build && expo-module build plugin",
    "clean": "expo-module clean && expo-module clean plugin",
    "lint": "expo-module lint",
    "test": "jest --selectProjects Node Web && jest --config plugin/jest.config.js",
    "prepare": "expo-module prepare && expo-module prepare plugin",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "docs": "typedoc",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "files": [
    "build",
    "plugin/build",
    "app.plugin.js",
    "ios",
    "android",
    "expo-module.config.json",
    "README.md"
  ],
  "keywords": [
    "react-native",
    "expo",
    "mapbox",
    "navigation",
    "turn-by-turn",
    "maps",
    "routing",
    "gps",
    "voice-guidance",
    "expo-module"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heumes-IT/expo-mapbox-navigation.git"
  },
  "bugs": {
    "url": "https://github.com/Heumes-IT/expo-mapbox-navigation/issues"
  },
  "author": "Mike Mestebeld <mike@heumes.nl>",
  "license": "MIT",
  "homepage": "https://github.com/Heumes-IT/expo-mapbox-navigation#readme",
  "dependencies": {
    "@expo/config-plugins": "^10.1.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.1",
    "expo": "^55.0.14",
    "expo-build-properties": "^55.0.13",
    "expo-module-scripts": "^55.0.2",
    "react-native": "0.83.4",
    "typedoc": "^0.28.19"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.83.0"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
